{
  "buildCommand": "node build.mjs",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/infiniteskill/(.*)",
      "destination": "/infiniteskill/index.html"
    },
    {
      "source": "/yuntype/(.*)",
      "destination": "/yuntype/index.html"
    },
    {
      "source": "/ai-slides/(.*)",
      "destination": "/ai-slides/index.html"
    },
    {
      "source": "/ai-presentation/(.*)",
      "destination": "/ai-presentation/index.html"
    },
    {
      "source": "/cyber-flying-sword/(.*)",
      "destination": "/cyber-flying-sword/index.html"
    },
    {
      "source": "/storyforge/(.*)",
      "destination": "/storyforge/index.html"
    },
    {
      "source": "/novel-game/(.*)",
      "destination": "/novel-game/index.html"
    },
    {
      "source": "/awesome-gpt-image-2/(.*)",
      "destination": "/awesome-gpt-image-2/index.html"
    },
    {
      "source": "/wechat-plugin/(.*)",
      "destination": "/wechat-plugin/index.html"
    }
  ]
}
