{
  "buildCommand": "node build.mjs",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/infiniteskill/(.*)",
      "destination": "/infiniteskill/index.html"
    },
    {
      "source": "/yuntype/(.*)",
      "destination": "/yuntype/index.html"
    },
    {
      "source": "/cyber-flying-sword/(.*)",
      "destination": "/cyber-flying-sword/index.html"
    },
    {
      "source": "/storyforge/(.*)",
      "destination": "/storyforge/index.html"
    }
  ]
}
